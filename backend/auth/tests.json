{
  "tests": [
    {
      "name": "Register new user",
      "method": "POST",
      "path": "/register",
      "body": {"name": "Тест Юзер", "phone": "+79991234567", "password": "test123"},
      "expectedStatus": 200,
      "expectedBody": {"token": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login existing user",
      "method": "POST",
      "path": "/login",
      "body": {"phone": "+79991234567", "password": "test123"},
      "expectedStatus": 200,
      "expectedBody": {"token": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login wrong password",
      "method": "POST",
      "path": "/login",
      "body": {"phone": "+79991234567", "password": "wrongpass"},
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Ping health check",
      "method": "GET",
      "path": "/ping",
      "expectedStatus": 200,
      "expectedBody": {"status": "ok"},
      "bodyMatcher": "partial"
    }
  ]
}